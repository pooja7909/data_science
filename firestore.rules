rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isSignedIn() { return request.auth != null; }
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(data) { 
      return isSignedIn() && (
        data.teacherId == request.auth.uid || 
        // Migration: Allow claiming documents that were created without a teacherId
        !data.keys().hasAll(['teacherId'])
      ); 
    }
    function isDocOwner(docId) { return isSignedIn() && docId == request.auth.uid; }

    // Pillar 2: Validation Blueprints
    function isValidStudent(data) {
      return data.keys().hasAll(['name', 'yearGroup', 'groupName', 'academicYear'])
        && data.name is string && data.name.size() <= 300
        && (data.yearGroup is string || data.yearGroup is number)
        && data.groupName is string && data.groupName.size() <= 100
        && data.academicYear is string && data.academicYear.size() <= 20
        && (!data.keys().hasAny(['baselineGrade']) || data.baselineGrade is string)
        && (!data.keys().hasAny(['preferredName']) || data.preferredName is string)
        && (!data.keys().hasAny(['notes']) || data.notes is string)
        && (!data.keys().hasAny(['isNew']) || data.isNew is bool)
        && (!data.keys().hasAny(['subjects']) || data.subjects is list)
        && (!data.keys().hasAny(['subjectLevels']) || data.subjectLevels is map);
    }

    function isValidGroup(data) {
      return data.keys().hasAll(['yearGroup', 'name', 'academicYear'])
        && (data.yearGroup is string || data.yearGroup is number)
        && data.name is string && data.name.size() <= 100
        && data.academicYear is string && data.academicYear.size() <= 20;
    }

    function isValidAssessment(data) {
      return data.keys().hasAll(['name', 'subject', 'maxMarks', 'yearGroup', 'academicYear', 'date'])
        && data.name is string && data.name.size() <= 300
        && data.subject is string && data.subject.size() <= 150
        && data.maxMarks is number && data.maxMarks >= 0
        && (data.yearGroup is string || data.yearGroup is number)
        && data.academicYear is string && data.academicYear.size() <= 20;
    }

    function isValidMark(data) {
      return data.keys().hasAll(['studentId', 'assessmentId', 'score'])
        && isValidId(data.studentId)
        && isValidId(data.assessmentId)
        && data.score is number;
    }

    // Match Blocks
    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidStudent(incoming());
      allow delete: if isSignedIn();
    }

    match /groups/{groupId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidGroup(incoming());
      allow delete: if isSignedIn();
    }

    match /assessments/{assessmentId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidAssessment(incoming());
      allow delete: if isSignedIn();
    }

    match /marks/{markId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidMark(incoming());
      allow delete: if isSignedIn();
    }

    match /config/shared_settings {
      allow read, write: if isSignedIn();
    }
  }
}
