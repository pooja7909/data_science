{
  "entities": {
    "Student": {
      "title": "Student",
      "description": "A student in the department.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Student's name" },
        "yearGroup": { "type": "number", "description": "Student's year group (7-13)" }
      },
      "required": ["name", "yearGroup"]
    },
    "Assessment": {
      "title": "Assessment",
      "description": "An assessment for a student.",
      "type": "object",
      "properties": {
        "studentId": { "type": "string", "description": "Reference to Student" },
        "assessmentName": { "type": "string", "description": "Name of the assessment" },
        "grade": { "type": "string", "description": "Grade achieved" },
        "date": { "type": "string", "format": "date", "description": "Date of assessment" }
      },
      "required": ["studentId", "assessmentName", "grade", "date"]
    }
  },
  "firestore": {
    "/students/{studentId}": {
      "schema": { "$ref": "Student" },
      "description": "Collection of students."
    },
    "/students/{studentId}/assessments/{assessmentId}": {
      "schema": { "$ref": "Assessment" },
      "description": "Collection of assessments for a student."
    }
  }
}
